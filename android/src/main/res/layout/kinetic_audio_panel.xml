<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/kinetic_audio_panel_width"
    android:layout_height="wrap_content"
    android:background="@drawable/kinetic_audio_panel_bg"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingTop="@dimen/kinetic_panel_padding_vertical"
    android:paddingBottom="@dimen/kinetic_panel_padding_vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/kinetic_audio_panel_slider_height"
        android:gravity="center">

        <SeekBar
            android:id="@+id/audio_panel_volume"
            android:layout_width="@dimen/kinetic_audio_panel_slider_height"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:max="100"
            android:maxHeight="4dp"
            android:minHeight="4dp"
            android:progress="100"
            android:progressDrawable="@drawable/kinetic_seek_progress"
            android:rotation="270"
            android:thumb="@drawable/kinetic_seek_thumb" />
    </FrameLayout>
</LinearLayout>
