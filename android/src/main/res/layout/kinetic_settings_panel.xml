<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/kinetic_settings_panel_width"
    android:layout_height="wrap_content"
    android:background="@drawable/kinetic_audio_panel_bg"
    android:orientation="vertical"
    android:padding="@dimen/kinetic_settings_panel_padding">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/kinetic_settings_title"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/kinetic_audio_tracks"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/settings_panel_track_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="vertical" />
</LinearLayout>
